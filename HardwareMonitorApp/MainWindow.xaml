<Window x:Class="HardwareMonitorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="하드웨어 모니터 프로" Height="650" Width="950"
        Background="#121212" Foreground="White" WindowStyle="None"
        AllowsTransparency="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    
    <Border CornerRadius="15" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단 헤더 -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🖥️ 하드웨어 실시간 모니터링" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="#E0E0E0"/>
                    <Border Background="#4CAF50" CornerRadius="4" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="관리자 모드" Foreground="White" Padding="8,3" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" 
                        BorderThickness="0" Foreground="#888" Cursor="Hand" Click="Close_Click" FontSize="20"/>
            </Grid>

            <!-- 메인 카드 레이아웃 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,20">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <!-- CPU 카드 -->
                        <Border Margin="10" Padding="20" Background="#252525" CornerRadius="15">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCpuName" Text="CPU 정보 확인 중..." Foreground="#888" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtCpuTemp" Text="-- °C" FontSize="38" FontWeight="Bold" Foreground="#FF5252" Margin="0,10"/>
                                <ProgressBar x:Name="PbCpuTemp" Value="0" Height="6" Background="#333" Foreground="#FF5252" BorderThickness="0"/>
                                <TextBlock Text="CPU 패키지 온도" Foreground="#666" FontSize="10" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- GPU 카드 -->
                        <Border Margin="10" Padding="20" Background="#252525" CornerRadius="15">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtGpuName" Text="GPU 정보 확인 중..." Foreground="#888" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtGpuTemp" Text="-- °C" FontSize="38" FontWeight="Bold" Foreground="#2196F3" Margin="0,10"/>
                                <ProgressBar x:Name="PbGpuTemp" Value="0" Height="6" Background="#333" Foreground="#2196F3" BorderThickness="0"/>
                                <TextBlock Text="GPU 코어 온도" Foreground="#666" FontSize="10" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- 저장장치 목록 섹션 -->
                    <TextBlock Text="💾 저장장치 상태 (HDD/SSD)" Margin="10,20,0,10" FontSize="16" FontWeight="Bold" Foreground="#E0E0E0"/>
                    <ItemsControl x:Name="ListStorage">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="10,5" Padding="15" Background="#252525" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type, StringFormat='[{0}] '}" FontWeight="Bold" Foreground="#4CAF50"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#DDD"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <TextBlock Text="가동 시간: " Foreground="#777" FontSize="11"/>
                                                <TextBlock Text="{Binding PowerOnHours}" Foreground="#4CAF50" FontSize="11" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding TemperatureDisplay}" FontSize="20" FontWeight="Bold" Foreground="#FFA000" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- 하단 제어 버튼 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="📀 CD-ROM 드라이브 열기" Padding="30,15" Background="#383838" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" Click="EjectCD_Click" FontWeight="Bold" FontSize="14">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
